{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Basic user information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["email", "createdAt", "updatedAt"]
    },
    "Project": {
      "title": "Client Project",
      "description": "A project created by a user",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "active", "completed"] },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "mindmapNodes": { "type": "array" },
        "mindmapEdges": { "type": "array" },
        "chatHistory": { "type": "array" },
        "tasks": { "type": "array" },
        "requirementsChat": { "type": "string" },
        "budgetEstimate": { "type": "string" },
        "businessModelCanvas": { "type": "object" }
      },
      "required": ["name", "ownerId", "status", "createdAt", "updatedAt"]
    },
    "WorkshopRegistration": {
      "title": "Workshop Registration",
      "description": "Registration details for the VibeCoding workshop",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "whatsapp": { "type": "string" },
        "problem": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "contacted", "reminded"] },
        "createdAt": { "type": "string" }
      },
      "required": ["name", "email", "whatsapp", "problem", "status", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Stores user profiles."
    },
    "projects/{projectId}": {
      "schema": "Project",
      "description": "Stores projects created by users."
    },
    "workshopRegistrations/{registrationId}": {
      "schema": "WorkshopRegistration",
      "description": "Stores workshop registrations."
    }
  }
}
