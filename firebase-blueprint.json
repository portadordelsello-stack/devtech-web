{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Basic user information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["email", "createdAt", "updatedAt"]
    },
    "Project": {
      "title": "Client Project",
      "description": "A project created by a user",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "active", "completed"] },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["name", "ownerId", "status", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Stores user profiles."
    },
    "projects/{projectId}": {
      "schema": "Project",
      "description": "Stores projects created by users."
    }
  }
}
